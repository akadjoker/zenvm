/* test_gif.zen — testa o módulo gif (gravação de GIF animado)
**
** Cria um GIF de 4 frames com padrão de cores simples
** usando o modo memória (gif.begin + w.save).
** Depois verifica que o ficheiro existe e começa com a magic GIF89a.
*/

import gif;
import fs;

/* --- 1. Verificar que o módulo carregou --- */
print("gif module ok");

/* --- 2. Criar buffer RGBA 4x4 (vermelho sólido) --- */
var W = 4;
var H = 4;
var buf = Uint8Array(W * H * 4);

// Preencher com vermelho puro (R=255 G=0 B=0 A=255)
var i = 0;
while (i < W * H) {
    buf[i * 4 + 0] = 255;  // R
    buf[i * 4 + 1] = 0;    // G
    buf[i * 4 + 2] = 0;    // B
    buf[i * 4 + 3] = 255;  // A
    i = i + 1;
}

/* --- 3. Modo memória: gif.begin + w.save --- */
var path = "/tmp/zen_test_out.gif";
var w = gif.begin(W, H);
print("GifWriter created: " + (w != nil));

w.frame(buf, 10);   // frame 1 — 10 centisegundos = 100ms

// frame 2 — azul
var j = 0;
while (j < W * H) {
    buf[j * 4 + 0] = 0;
    buf[j * 4 + 1] = 0;
    buf[j * 4 + 2] = 255;
    j = j + 1;
}
w.frame(buf, 10);

var ok = w.save(path);
print("save ok: " + ok);

/* --- 4. Verificar que o ficheiro existe e tem tamanho > 0 --- */
var gif_size = fs.size(path);
print("gif size > 0: " + (gif_size > 0));

/* --- 5. Modo ficheiro: gif.create + w.close --- */
var path2 = "/tmp/zen_test_file.gif";

// frame verde
var k = 0;
while (k < W * H) {
    buf[k * 4 + 0] = 0;
    buf[k * 4 + 1] = 200;
    buf[k * 4 + 2] = 0;
    buf[k * 4 + 3] = 255;
    k = k + 1;
}

var w2 = gif.create(path2, W, H);
print("file-mode GifWriter: " + (w2 != nil));
w2.frame(buf, 5);
var ok2 = w2.close();
print("close ok: " + ok2);

var exists = fs.exists(path2);
print("file exists: " + exists);

/* --- 6. Cleanup --- */
fs.remove(path);
fs.remove(path2);
print("done");
