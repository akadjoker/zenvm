// test_raylib_window.zen — abre janela, desenha 1 frame, fecha
// Testa: init_fn, window lifecycle, draw, GC seguro após CloseWindow

InitWindow(400, 300, "zen raylib test");
SetTargetFPS(60);

BeginDrawing();
ClearBackground(30, 30, 40, 255);
DrawRectangle(50, 50, 100, 80, 255, 100, 50, 255);
DrawCircle(250, 150, 40.0, 50, 200, 255, 255);
DrawText("zen + raylib ok!", 80, 200, 20, 255, 255, 255, 255);
DrawFPS(10, 10);
EndDrawing();

CloseWindow();
print("janela fechada sem crash");
