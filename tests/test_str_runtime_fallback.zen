// Test: OP_TOSTRING runtime path calls __str__ even when compile-time type is unknown.

class Label {
    var text;

    def init(text) {
        self.text = text;
    }

    def __str__() {
        return "Label[" + self.text + "]";
    }
}

def pick(flag) {
    if (flag) {
        return Label("yes");
    }
    return Label("no");
}

var x = pick(true);
var y = pick(false);

print(x);
print("x={x}");
print(y);
print("y={y}");
print("ok: __str__ runtime fallback");
