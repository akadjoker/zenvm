import ini;

// parse básico
var text = "[window]\nwidth=800\nheight=600\ntitle=My Game\n\n[audio]\nvolume=75\nmuted=false\n";
var cfg = ini.parse(text);
print(cfg["window"]["width"]);
print(cfg["window"]["title"]);
print(cfg["audio"]["volume"]);
print(cfg["audio"]["muted"]);

// ini.get com default
print(ini.get(cfg, "window", "width"));
print(ini.get(cfg, "window", "missing", "default_val"));
print(ini.get(cfg, "nope", "key", "fallback"));

// comentários e valores com #
var text2 = "; config\n[db]\nhost=localhost # production\nport=5432\nname=myapp\n";
var cfg2 = ini.parse(text2);
print(cfg2["db"]["host"]);
print(cfg2["db"]["port"]);

// quoted values
var text3 = "[meta]\ndesc=\"hello, world\"\npath='C:\\\\files'\n";
var cfg3 = ini.parse(text3);
print(cfg3["meta"]["desc"]);

// stringify roundtrip
var s = ini.stringify(cfg);
var cfg4 = ini.parse(s);
print(cfg4["window"]["width"]);
print(cfg4["audio"]["volume"]);

// save + load
ini.save(cfg, "/tmp/test_zen.ini");
var cfg5 = ini.load("/tmp/test_zen.ini");
print(cfg5["window"]["height"]);
