struct Vec3 { x, y, z }

def bench() {
    var v1 = Vec3(1.1, 2.2, 3.3);
    var v2 = Vec3(4.4, 5.5, 6.6);
    var acc = 0.0;
    var n = 1000000;
    var i = 0;
    while (i < n) {
        var ax = v1.x;
        var bx = v2.x;
        var ay = v1.y;
        var by = v2.y;
        var az = v1.z;
        var bz = v2.z;
        acc = acc + ax * bx + ay * by + az * bz;
        i = i + 1;
    }
    return acc;
}
var t = clock();
var r = bench();
print(clock() - t);
print(r);
