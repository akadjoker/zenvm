import xml;

// --- parse from string ---
var doc = xml.parse("<root><item id='1' type='fruit'>apple</item><item id='2' type='veg'>carrot</item></root>");
var root = doc.root();
print(root.name());

var item1 = root.child("item");
print(item1.name());
print(item1.text());
print(item1.attr("id"));
print(item1.attr("type"));
print(item1.attr("missing") == nil);

// --- iterate siblings ---
var ch = root.firstChild();
var count = 0;
while (ch != nil) {
    count = count + 1;
    ch = ch.next();
}
print(count);

// --- children() array ---
var kids = root.children();
print(kids.len());
print(kids[1].text());

// --- attrs() map ---
var a = item1.attrs();
print(a["id"]);
print(a["type"]);

// --- build document ---
var doc2 = xml.create();
var r = doc2.createElement("config");
doc2.setRoot(r);

var e1 = doc2.createElement("window");
e1.setAttr("width", 800);
e1.setAttr("height", 600);
r.append(e1);

var e2 = doc2.createElement("title");
e2.setText("My Game");
r.append(e2);

var s = doc2.toString();
print(s != "");
print(doc2.error());

// --- elem toString ---
print(e2.toString() != "");

// --- nested children ---
var inner = doc2.createElement("mode");
inner.setText("fullscreen");
e1.append(inner);
var e1kids = e1.children();
print(e1kids.len());
print(e1kids[0].text());

// --- save and reload ---
doc2.saveFile("/tmp/test_zen.xml");
var doc3 = xml.load("/tmp/test_zen.xml");
var r3 = doc3.root();
print(r3.name());
print(r3.child("title").text());
print(r3.child("window").attr("width"));
