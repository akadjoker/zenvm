import file;

// Write binary data
var f = file.open("/tmp/test_zen.bin", "w");
file.write_byte(f, 255);
file.write_short(f, 1234);
file.write_int(f, 987654);
file.write_long(f, 1234567890123);
file.write_float(f, 3.14);
file.write_double(f, 2.718281828);
file.write_string(f, "hello zen");
file.close(f);

// Read it back
var g = file.open("/tmp/test_zen.bin", "r");
print(file.read_byte(g));
print(file.read_short(g));
print(file.read_int(g));
print(file.read_long(g));
print(file.read_float(g));
print(file.read_double(g));
print(file.read_string(g));
print(file.eof(g));
print(file.size(g));
file.close(g);
