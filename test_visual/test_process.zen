    {
        draw_text("main",20,20,12,255,255,255,255);
        if(mouse_down(0))
        {
              particle(mouse_x(),mouse_y(), math.random(4) - 2, math.random(4) - 2);
              
            /*var j = 0;
            while (j < 1000) {
                particle(mouse_x(),mouse_y(), math.random(4) - 2, math.random(4) - 2);
                j = j + 1;
            }
            */
        }
        frame;
    }
}

main();